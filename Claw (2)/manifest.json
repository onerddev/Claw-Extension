{
  "manifest_version": 3,
  "name": "Claw",
  "version": "18.0",
  "description": "Kahoot · StopotS · Tradutor · Resumidor · Explicador. Por Emanuel Felipe.",
  "permissions": ["activeTab","scripting","storage","tabs"],
  "host_permissions": [
    "https://kahoot.it/*","https://*.kahoot.it/*",
    "https://stopots.com/*","https://*.stopots.com/*",
    "https://api.groq.com/*","<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {"16":"icons/icon16.png","48":"icons/icon48.png","128":"icons/icon128.png"}
  },
  "background": {"service_worker": "background.js"},
  "content_scripts": [
    {"matches":["https://kahoot.it/*","https://*.kahoot.it/*"],"js":["stats.js","kahoot.js"],"run_at":"document_idle"},
    {"matches":["https://stopots.com/*","https://*.stopots.com/*"],"js":["stats.js","stopots.js"],"run_at":"document_idle"}
  ],
  "web_accessible_resources": [{"resources":["claude-icon.png","icons/*.png"],"matches":["<all_urls>"]}],
  "icons": {"16":"icons/icon16.png","48":"icons/icon48.png","128":"icons/icon128.png"}
}
